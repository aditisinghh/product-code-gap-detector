# Bob API (MCP) — the LLM reasoning engine
BOB_API_URL=http://localhost:11434   # or your Bob MCP endpoint
BOB_MODEL=granite-3-8b-instruct      # model ID passed to Bob

# Optional: real Jira connection (leave blank to use mock data)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# Optional: GitHub token for private repos
GITHUB_TOKEN=

# Cloned repos are cached here
REPO_CACHE_DIR=./repo_cache
